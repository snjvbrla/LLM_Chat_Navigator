{
    "manifest_version": 3,
    "name": "LLM_Chat_Navigator",
    "version": "1.2",
    "description": "大模型对话导航增强插件，针对模型生成超长回答的场景，提供侧边栏、大纲与快速跳转",
    "browser_specific_settings": {
        "gecko": {
            "id": "llm-chat-navigator@example.com",
            "strict_min_version": "109.0"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://chatgpt.com/*"
            ],
            "css": [
                "shared/styles.css"
            ],
            "js": [
                "shared/utils.js",
                "shared/ui.js",
                "portals/chatgpt/adapter.js",
                "shared/main.js"
            ]
        },
        {
            "matches": [
                "*://gemini.google.com/*"
            ],
            "css": [
                "shared/styles.css"
            ],
            "js": [
                "shared/utils.js",
                "shared/ui.js",
                "portals/gemini/adapter.js",
                "shared/main.js"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "24": "icons/icon24.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png"
        }
    }
}
