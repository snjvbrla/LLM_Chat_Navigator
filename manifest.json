{
    "manifest_version": 3,
    "name": "ChatGPT Prompt Sidebar",
    "version": "1.1",
    "description": "在侧边栏显示所有的提示词",
    "content_scripts": [
        {
            "matches": [
                "*://chatgpt.com/*"
            ],
            "css": [
                "styles.css"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "24": "icons/icon24.png",
        "32": "icons/icon42.png",
        "48": "icons/icon48.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png"
        }
    }
}